# =====================================================================
# DOA AGENT — Environment Configuration
# =====================================================================
# Copy this file to `.env` and fill in keys you want to use.
# Everything here has sane defaults; the agent runs in PAPER-TRADING mode
# with NO keys at all (it'll use a heuristic NLP fallback + free RSS).
# =====================================================================

# -------- General ----------------------------------------------------
LOG_LEVEL=INFO
# SQLite file for local dev. In production set a Postgres URL (e.g. Neon /
# Render Postgres): postgresql://user:pass@host/db — see app/database.py.
DATABASE_URL=sqlite:///./data/doa.db
HOST=0.0.0.0
PORT=8000

# -------- CORS --------------------------------------------------------
# Comma-separated allowlist of browser origins. Defaults cover local dev
# (Vite on 5173, FastAPI-served build on 8000). In production set this to
# your deployed frontend origin(s) ONLY.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# -------- Agent behavior --------------------------------------------
# How often the orchestrator loop runs (seconds).
LOOP_INTERVAL_SECONDS=30

# Probability delta required to trigger a trade (e.g. 0.08 = 8 cents on a 0-1 scale).
EDGE_THRESHOLD=0.08

# Minimum LLM/heuristic confidence to act on a signal (0-1).
MIN_SIGNAL_CONFIDENCE=0.55

# -------- Risk limits (Overseer) -------------------------------------
MAX_USDC_PER_TRADE=10
MAX_OPEN_POSITIONS=5
DAILY_DRAWDOWN_USDC=25
KILL_SWITCH=false

# -------- Admin auth ---------------------------------------------------
# Bearer token required to call the control endpoints: POST /api/kill-switch
# and POST /api/loop/{run-once,start,stop}. CORS does not stop curl, so
# these are gated by a shared secret, sent as `Authorization: Bearer <token>`.
# Leave unset to disable those endpoints entirely (they return 503) rather
# than run them open.
ADMIN_TOKEN=

# -------- Trading mode -----------------------------------------------
# PAPER (safe, simulated) or LIVE (signs real Polymarket transactions).
# LIVE requires WALLET_PRIVATE_KEY below and is wired but locked down by
# default. Use at your own risk.
TRADING_MODE=PAPER
WALLET_PRIVATE_KEY=
POLYGON_RPC_URL=https://polygon-rpc.com

# -------- Data sources (Scout) ---------------------------------------
# Free, no key required:
RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://cointelegraph.com/rss,https://decrypt.co/feed
# Free tier, optional:
CRYPTOPANIC_API_KEY=

# -------- LLM (Quant) ------------------------------------------------
# Priority: GROQ -> OPENAI -> ANTHROPIC -> heuristic fallback (always works).
# Groq has a generous free tier with fast Llama 3.1 inference.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# -------- Market focus (Oracle) --------------------------------------
# Comma-separated Polymarket condition_ids or market slugs to monitor.
# Leave empty to auto-pick top crypto markets by volume.
WATCH_MARKETS=
MARKET_KEYWORDS=bitcoin,ethereum,crypto,sec,etf,fed
MAX_MARKETS=5

# -------- x402 paywall (workshop / monetization) -----------------------
# When X402_ENABLED=true, X402_PAY_TO MUST be a real 0x address — the app
# refuses to start otherwise (no silent fallback; see x402_setup.py).
# Create a Base Sepolia wallet (OWS or MetaMask), fund USDC at
# https://faucet.circle.com/ (select Base Sepolia), then set your 0x address.
X402_ENABLED=false
X402_PAY_TO=
X402_PRICE=$0.01
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=eip155:84532
